# OpenFEC API key — free at https://api.open.fec.gov/developers/
FEC_API_KEY=DEMO_KEY

# Congress.gov API key — free at https://api.congress.gov/sign-up/
CONGRESS_API_KEY=

# How many top-funded bills to surface (default 20)
TOP_N_BILLS=20

# Filing years to sweep (defaults to current congress cycle)
# SWEEP_YEARS=2025,2026

# Rate-limit delays in seconds between API pages
# LDA_REQUEST_DELAY=1.0
# FEC_REQUEST_DELAY=0.5
